# Anthropic API（サーバ専用・クライアントに出さない）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase（サーバ専用。全アクセスがサーバ側のため publishable/anon キーで足りる）
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud Text-to-Speech（相棒の読み上げ／サーバ専用・クライアントに出さない）
# Cloud Text-to-Speech API を有効化し、API キーを発行して設定する。WaveNet は月100万字まで無料枠。
GOOGLE_TTS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
